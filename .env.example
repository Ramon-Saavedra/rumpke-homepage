# Application Environment
NODE_ENV=production

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend Configuration (when ready)
# DATABASE_URL=postgresql://rumpke:password@database:5432/rumpke_db
# JWT_SECRET=your-jwt-secret-here

# Database Configuration (when ready)
# DB_USER=rumpke
# DB_PASSWORD=your-secure-password
# DB_NAME=rumpke_db

# AWS Configuration (for deployment)
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# External APIs (when ready)
# ONOFFICE_API_KEY=your-onoffice-api-key
# ONOFFICE_API_SECRET=your-onoffice-secret

